# Variables de entorno para desarrollo local con Vercel CLI (vercel dev)
# NUNCA subas este archivo a Git. Está en .gitignore.

# Tu Truora API Key (obtenida en https://app.truora.com → API Keys)
TRUORA_API_KEY=tu_truora_api_key_aqui

# El flow_id de tu flujo creado en el dashboard de Truora
TRUORA_FLOW_ID=tu_flow_id_aqui

# URL pública de tu app (solo para desarrollo local; en Vercel se auto-detecta)
APP_URL=http://localhost:3000
